PORT=4000
# Local dev without Docker: embedded Postgres (PGlite). Set to 0 to use DATABASE_URL only.
USE_PGLITE=1
# Linux / Docker Postgres default:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insurance_crm
# MacBook (Homebrew): use your login name from Terminal: whoami — often no password:
DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/insurance_crm
JWT_SECRET=change-this-to-a-long-random-string-in-production
OPENAI_API_KEY=
# Comma-separated browser origins allowed to call the API (CORS). Add your Vercel URL and custom domain.
# Example: https://my-app.vercel.app,https://crm.example.com
FRONTEND_ORIGIN=http://localhost:5173
